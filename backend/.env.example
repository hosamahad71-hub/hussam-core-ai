APP_NAME=HussamCore
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=hussam_core
DB_USERNAME=hussam
DB_PASSWORD=secret

CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=cookie

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost
SESSION_DOMAIN=localhost

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

# Tenancy
TENANCY_STRATEGY=schema
TENANT_HEADER=X-Tenant-ID
DEFAULT_TENANT_CODE=hussam
